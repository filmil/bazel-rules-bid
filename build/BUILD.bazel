package(
    default_visibility = ["//visibility:public"],
)

gotopt2_generate_bash(
    name = "docker_run_flags",
    src = "docker_run_flags.yaml",
    out = "docker_run_flags.bash",
)

sh_binary(
    name = "docker_run",
    srcs = ["docker_run.sh"],
    data = [
        "docker_run_flags.bash",
        "@bazel_tools//tools/bash/runfiles",
        "@fshlib//:log",
    ],
    deps = [
        ":resolve",
    ],
)

sh_library(
    name = "resolve",
    srcs = [
        "resolve_workspace.bash",
        "@multitool//tools/gotopt2",
    ],
)

bzl_library(
    name = "rules",
    srcs = ["rules.bzl"],
)
